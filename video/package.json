    "render:captured-demo": "node scripts/render-captured-demo.mjs",
    "still:captured-demo": "node scripts/still-captured-demo.mjs"
  },
  "dependencies": {
    "@remotion/cli": "4.0.436",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remotion": "4.0.436",
    "zod": "4.3.6"
